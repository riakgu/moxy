{
    "proxy": {
        "ipv4": {
            "port": 1080,
            "slot_port_start": 10000
        },
        "ipv6": {
            "port": 2080,
            "slot_port_start": 20000
        },
        "source_ip_strategy": "round-robin",
        "udp_idle_timeout_seconds": 60,
        "udp_max_associations": 256
    },
    "api": {
        "port": 8080
    },
    "devices": {
        "grace_period_seconds": 30,
        "watcher_reconnect_max_seconds": 30,
        "drain_timeout_seconds": 10
    },
    "slots": {
        "max_slots": 1000,
        "max_slots_per_device": 500,
        "ip_check_host": "ip.moxy.my.id",
        "monitor_steady_interval_seconds": 60,
        "monitor_recovery_interval_seconds": 5,
        "monitor_unhealthy_threshold": 3
    },
    "dns": {
        "cache_max_entries_per_device": 10000,
        "cache_min_ttl_seconds": 30,
        "cache_max_ttl_seconds": 300
    },
    "traffic": {
        "max_tracked": 5000
    },
    "sse": {
        "debounce_ms": 1000,
        "heartbeat_seconds": 30,
        "max_clients": 10,
        "traffic_snapshot_limit": 100
    },
    "server": {
        "shutdown_drain_seconds": 30
    },
    "log": {
        "level": "info",
        "format": "json"
    }
}