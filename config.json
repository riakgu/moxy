{
    "proxy": {
        "socks5_port": 1080,
        "http_port": 8080,
        "max_connections": 500,
        "dial_timeout_seconds": 10,
        "idle_timeout_seconds": 300,
        "source_ip_strategy": "random",
        "port_based_start": 10000,
        "port_based_end": 10250
    },
    "api": {
        "port": 9090
    },
    "slots": {
        "max_slots_per_device": 250,
        "discovery_interval_seconds": 30,
        "discovery_concurrency": 20,
        "monitor_interval_seconds": 300
    },
    "provision": {
        "dns64_server": "2001:4860:4860::6464"
    },
    "database": {
        "path": "moxy.db"
    },
    "server": {
        "shutdown_drain_seconds": 30
    },
    "log": {
        "level": "info",
        "format": "json"
    }
}