{
    "proxy": {
        "port": 1080,
        "slot_port_start": 10000,
        "ipv6_port": 2080,
        "ipv6_slot_port_start": 20000,
        "source_ip_strategy": "round-robin"
    },
    "api": {
        "port": 8080
    },
    "devices": {
        "grace_period_seconds": 30,
        "watcher_reconnect_max_seconds": 30,
        "drain_timeout_seconds": 10
    },
    "slots": {
        "max_slots_per_device": 250,
        "ip_check_host": "ip.moxy.my.id",
        "monitor_fast_interval_seconds": 10,
        "monitor_steady_interval_seconds": 60,
        "monitor_recovery_interval_seconds": 15,
        "monitor_fast_ticks": 6,
        "monitor_unhealthy_threshold": 3
    },
    "dns": {
        "cache_max_entries_per_device": 10000,
        "cache_min_ttl_seconds": 30,
        "cache_max_ttl_seconds": 300
    },
    "traffic": {
        "max_tracked": 5000
    },
    "server": {
        "shutdown_drain_seconds": 30
    },
    "log": {
        "level": "info",
        "format": "json"
    }
}